Def_Driver 'Drv1'
  Sd=132.00cm2
  Re=5.80ohm
  Le=0.35mH
  Fs=34.00Hz
  Qes=0.42
  Qms=4.10
  Vas=55.00L

Source 'V1' Node=1=0
  V=2.83V  Rs=0.00ohm

Driver 'Drv' Def='Drv1' Node=1=0=2=3

Radiator 'FrontRad' Node=2
  Sd=132.00cm2  Win=2pi

Enclosure 'RearVol' Node=3
  Vb=18.00L  Lb=18.00cm

